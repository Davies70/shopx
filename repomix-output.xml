              </div>

              {cartItems.length === 0 && (
                <div className='flex-1 justify-center w-full  items-center absolute left-0 right-0 top-[20%]'>
                  <div className='grid grid-cols-[1fr] grid-rows-[auto] gap-y-[24px] gap-x-[16px] justify-items-center'>
