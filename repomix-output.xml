            transition={{ duration: 0.4, ease: [0.25, 0.46, 0.45, 0.94] }}
            className='w-[93%] min-w-[auto] min-[480px]:w-[90%] min-[480px]:min-w-[300px] max-w-[625px] bg-white mt-0 pt-0 overflow-hidden flex flex-col'
          >
