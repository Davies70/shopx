        </div>

        <div className='z-[2] flex absolute items-center justify-center bottom-[36px] flex-row min-[992px]:bottom-[40px] h-[48px] min-h-[12px] m-auto p-0 text-[6px] top-auto left-0 right-0 transform-none'>
