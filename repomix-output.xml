    setCurrentIndex((prevIndex) =>
      prevIndex === 0 ? slidesOne.length - 1 : prevIndex - 1
    );
  };

  return (
    <section className='min-h-[93vh] min-[480px]:min-h-[100vh] flex flex-row  bg-[#080808] justify-center'>
