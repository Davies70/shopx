  gsap.registerPlugin(ScrollToPlugin);

  const scrollToRef = () => {
    if (scrollRef.current) {
      gsap.to(window, {
        duration: 2, // seconds
        scrollTo: scrollRef.current,
        ease: 'power2.inOut',
      });
    }
  };

