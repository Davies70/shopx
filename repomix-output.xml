              rotate: springImage2Rotate,
              willChange: 'transform',
            }}
            className='max-[991px]:row-start-2 relative border overflow-hidden w-[30vw] h-[45vw] min-[768px]:w-[20vw] min-[768px]:h-[29vw] min-[992px]:w-[15vw] min-[992px]:h-[21vw]'
